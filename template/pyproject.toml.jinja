[project]
name = "{{ project_slug }}"
version = "0.1.0"
description = "{{ project_description }}"
requires-python = ">={{ python_version }}"
dependencies = [
    "{{ pkg_slug }}-core",
    "{{ pkg_slug }}-backend",
    "{{ pkg_slug }}-cli",
{%- if desktop_framework == 'pywebview' %}
    # Desktop shell — drop this line for server-only deployments.
    "{{ pkg_slug }}-desktop",
{%- elif desktop_framework == 'pyside6' %}
    # Desktop shell — drop this line for server-only deployments.
    "{{ pkg_slug }}-desktop-qt",
{%- endif %}
    # Example plugins — installed so they are discovered via entry points.
    # Remove these three lines to ship without the bundled examples.
    "{{ pkg_slug }}-plugin-basic",
    "{{ pkg_slug }}-plugin-cli",
    "{{ pkg_slug }}-plugin-paid",
    # NOTE: {{ pkg_slug }}-plugin-reports is intentionally NOT installed — it is
    # the marketplace demo. Install it on demand: uv add {{ pkg_slug }}-plugin-reports
]

[tool.uv]
package = false

[tool.uv.workspace]
members = [
    "packages/*",
    "apps/backend",
    "apps/cli",
{%- if desktop_framework == 'pywebview' %}
    "apps/desktop",
{%- elif desktop_framework == 'pyside6' %}
    "apps/desktop-qt",
{%- endif %}
    "extensions/*",
]

[tool.uv.sources]
"{{ pkg_slug }}-core" = { workspace = true }
"{{ pkg_slug }}-backend" = { workspace = true }
"{{ pkg_slug }}-cli" = { workspace = true }
{%- if desktop_framework == 'pywebview' %}
"{{ pkg_slug }}-desktop" = { workspace = true }
{%- elif desktop_framework == 'pyside6' %}
"{{ pkg_slug }}-desktop-qt" = { workspace = true }
{%- endif %}
"{{ pkg_slug }}-plugin-api" = { workspace = true }
"{{ pkg_slug }}-licensing" = { workspace = true }
"{{ pkg_slug }}-plugin-basic" = { workspace = true }
"{{ pkg_slug }}-plugin-cli" = { workspace = true }
"{{ pkg_slug }}-plugin-paid" = { workspace = true }
"{{ pkg_slug }}-plugin-reports" = { workspace = true }

[dependency-groups]
dev = [
    "pytest>=8",
    "ruff>=0.6",
    "httpx>=0.27",
]
docs = [
    "mkdocs-material>=9.5",
    "pymdown-extensions>=10.7",
]
{%- if desktop_framework != 'none' %}
build = [
    "pyinstaller>=6.10",
]
{%- endif %}

[tool.ruff]
line-length = 100
target-version = "py{{ python_version | replace('.', '') }}"
src = ["packages", "apps"]

[tool.ruff.lint]
select = ["E", "F", "I", "UP", "B"]

[tool.ruff.lint.isort]
known-first-party = [
    "{{ pkg_slug }}_core",
    "{{ pkg_slug }}_backend",
    "{{ pkg_slug }}_cli",
{%- if desktop_framework == 'pywebview' %}
    "{{ pkg_slug }}_desktop",
{%- elif desktop_framework == 'pyside6' %}
    "{{ pkg_slug }}_desktop_qt",
{%- endif %}
    "{{ pkg_slug }}_plugin_api",
    "{{ pkg_slug }}_licensing",
    "{{ pkg_slug }}_plugin_basic",
    "{{ pkg_slug }}_plugin_cli",
    "{{ pkg_slug }}_plugin_paid",
    "{{ pkg_slug }}_plugin_reports",
]

[tool.ruff.lint.flake8-bugbear]
# Typer relies on function calls in argument defaults for CLI declarations.
extend-immutable-calls = ["typer.Argument", "typer.Option"]

[tool.pytest.ini_options]
addopts = "-q"
testpaths = ["packages", "apps"]
