[project]
name = "{{ project_slug }}"
version = "0.1.0"
description = "{{ project_description }}"
requires-python = ">={{ python_version }}"
dependencies = [
    "{{ pkg_slug }}-core",
    "{{ pkg_slug }}-backend",
    "{{ pkg_slug }}-cli",
    # Example plugins — installed so they are discovered via entry points.
    # Remove these three lines to ship without the bundled examples.
    "{{ pkg_slug }}-plugin-basic",
    "{{ pkg_slug }}-plugin-cli",
    "{{ pkg_slug }}-plugin-paid",
]

[tool.uv]
package = false

[tool.uv.workspace]
members = ["packages/*", "apps/backend", "apps/cli", "extensions/*"]

[tool.uv.sources]
"{{ pkg_slug }}-core" = { workspace = true }
"{{ pkg_slug }}-backend" = { workspace = true }
"{{ pkg_slug }}-cli" = { workspace = true }
"{{ pkg_slug }}-plugin-api" = { workspace = true }
"{{ pkg_slug }}-licensing" = { workspace = true }
"{{ pkg_slug }}-plugin-basic" = { workspace = true }
"{{ pkg_slug }}-plugin-cli" = { workspace = true }
"{{ pkg_slug }}-plugin-paid" = { workspace = true }

[dependency-groups]
dev = [
    "pytest>=8",
    "ruff>=0.6",
    "httpx>=0.27",
]

[tool.ruff]
line-length = 100
target-version = "py{{ python_version | replace('.', '') }}"
src = ["packages", "apps"]

[tool.ruff.lint]
select = ["E", "F", "I", "UP", "B"]

[tool.ruff.lint.isort]
known-first-party = [
    "{{ pkg_slug }}_core",
    "{{ pkg_slug }}_backend",
    "{{ pkg_slug }}_cli",
    "{{ pkg_slug }}_plugin_api",
    "{{ pkg_slug }}_licensing",
    "{{ pkg_slug }}_plugin_basic",
    "{{ pkg_slug }}_plugin_cli",
    "{{ pkg_slug }}_plugin_paid",
]

[tool.ruff.lint.flake8-bugbear]
# Typer relies on function calls in argument defaults for CLI declarations.
extend-immutable-calls = ["typer.Argument", "typer.Option"]

[tool.pytest.ini_options]
addopts = "-q"
testpaths = ["packages", "apps"]
