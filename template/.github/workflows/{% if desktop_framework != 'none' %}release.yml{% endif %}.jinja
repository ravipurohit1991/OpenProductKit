name: Release

# Tag-triggered desktop releases: push a version tag (v1.2.3) and this builds
# the desktop app on every OS and attaches the installers to a GitHub Release.
# Run it manually (workflow_dispatch) for a dry run — installers land as
# workflow artifacts instead. Code signing / notarization is intentionally not
# wired in: it needs your certificates and your decisions — see the docs.
#
# NOTE: rendered by Copier; GitHub Actions expressions live in raw blocks so
# the two template languages never collide.

on:
  push:
    tags: ["v*"]
  workflow_dispatch:

permissions:
  contents: write

jobs:
  build:
{% raw %}    name: build (${{ matrix.os }})
    runs-on: ${{ matrix.os }}
{% endraw %}    strategy:
      fail-fast: false
      matrix:
        os: [windows-latest, macos-latest, ubuntu-latest]
    defaults:
      run:
        shell: bash
    steps:
      - uses: actions/checkout@v4

      - name: Install uv
        uses: astral-sh/setup-uv@v5
        with:
          python-version: "{{ python_version }}"

      - uses: pnpm/action-setup@v4
        with:
          version: 9

      - uses: actions/setup-node@v4
        with:
          node-version: 22
          cache: pnpm
{%- if desktop_framework == 'tauri' %}

      - name: Install Rust
        uses: dtolnay/rust-toolchain@stable

      - name: Install Tauri system deps (Linux)
        if: runner.os == 'Linux'
        run: |
          sudo apt-get update
          sudo apt-get install -y libwebkit2gtk-4.1-dev libgtk-3-dev librsvg2-dev
{%- endif %}

      - run: uv sync --dev

      - run: pnpm install

      - name: Build the desktop app
        run: uv run {{ cli_name }} build desktop
{%- if desktop_framework == 'electron' %}
        env:
          # Unsigned builds by design; add your certificates to sign.
          CSC_IDENTITY_AUTO_DISCOVERY: "false"
{%- endif %}
{%- if desktop_framework == 'pywebview' %}

      # PyInstaller onedir output: zip on Windows, tar.gz elsewhere (tar keeps
      # the executable bits that a plain zip would drop).
      - name: Package (Windows)
        if: runner.os == 'Windows'
        run: cd dist && 7z a "{{ project_slug }}-windows.zip" "{{ project_slug }}"

      - name: Package (macOS/Linux)
        if: runner.os != 'Windows'
        run: |
          os_name=$(echo "$RUNNER_OS" | tr '[:upper:]' '[:lower:]')
          tar -czf "dist/{{ project_slug }}-${os_name}.tar.gz" -C dist "{{ project_slug }}"
{%- endif %}

      - name: Attach installers to the GitHub Release
        if: startsWith(github.ref, 'refs/tags/')
{% raw %}        env:
          GH_TOKEN: ${{ github.token }}
{% endraw %}        run: |
          shopt -s nullglob
{%- if desktop_framework == 'pywebview' %}
          files=(dist/*.zip dist/*.tar.gz)
{%- elif desktop_framework == 'electron' %}
          # latest*.yml are the electron-updater feed files — keep them next
          # to the installers if you wire up auto-update.
          files=(dist/electron/*.exe dist/electron/*.dmg dist/electron/*.AppImage dist/electron/*.zip dist/electron/latest*.yml)
{%- elif desktop_framework == 'tauri' %}
          bundle=apps/desktop-tauri/src-tauri/target/release/bundle
          files=("$bundle"/msi/*.msi "$bundle"/nsis/*.exe "$bundle"/dmg/*.dmg "$bundle"/appimage/*.AppImage "$bundle"/deb/*.deb)
{%- endif %}
          gh release create "$GITHUB_REF_NAME" --title "$GITHUB_REF_NAME" --generate-notes || true
          gh release upload "$GITHUB_REF_NAME" "${files[@]}" --clobber

      - name: Upload workflow artifacts (dry run)
        if: "!startsWith(github.ref, 'refs/tags/')"
        uses: actions/upload-artifact@v4
        with:
{% raw %}          name: desktop-${{ matrix.os }}
{% endraw %}          path: |
{%- if desktop_framework == 'pywebview' %}
            dist/*.zip
            dist/*.tar.gz
{%- elif desktop_framework == 'electron' %}
            dist/electron/*.exe
            dist/electron/*.dmg
            dist/electron/*.AppImage
            dist/electron/*.zip
            dist/electron/latest*.yml
{%- elif desktop_framework == 'tauri' %}
            apps/desktop-tauri/src-tauri/target/release/bundle/msi/*.msi
            apps/desktop-tauri/src-tauri/target/release/bundle/nsis/*.exe
            apps/desktop-tauri/src-tauri/target/release/bundle/dmg/*.dmg
            apps/desktop-tauri/src-tauri/target/release/bundle/appimage/*.AppImage
            apps/desktop-tauri/src-tauri/target/release/bundle/deb/*.deb
{%- endif %}
          if-no-files-found: warn
