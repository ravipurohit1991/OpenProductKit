"""The {{ project_name }} desktop shell.

One process, no HTTP: pywebview opens a native window on the built web UI
(loaded from disk), and every API call crosses the JS bridge into `Api.request`
below, which dispatches to the *same FastAPI app* through an in-process ASGI
client. There is no socket, no port, no sidecar process to babysit or sign
separately — the core is simply called in-process, which is the whole point of
the hexagonal split.

Run it with `{{ cli_name }} desktop` (after `{{ cli_name }} build web`), or
package it with `{{ cli_name }} build desktop`.
"""

from __future__ import annotations

import argparse
import os
import sys
from pathlib import Path

from platformdirs import user_data_dir

WINDOW_TITLE = "{{ project_name }}"
DATA_DIR_NAME = "{{ project_slug }}"


def prepare_environment() -> Path:
    """Point the app at a per-user data directory (database, license file).

    Must run before the backend settings module is imported, which is why the
    backend imports below live inside functions.
    """
    data_dir = Path(user_data_dir(DATA_DIR_NAME, appauthor=False))
    data_dir.mkdir(parents=True, exist_ok=True)
    db_path = (data_dir / "app.db").as_posix()
    os.environ.setdefault("APP_DATABASE_URL", f"sqlite:///{db_path}")
    os.environ.setdefault("APP_LICENSE_FILE", str(data_dir / "license.key"))
    return data_dir


class Api:
    """The JS<->Python bridge; `window.pywebview.api.request(...)` lands here."""

    def __init__(self, client) -> None:  # client: fastapi.testclient.TestClient
        self._client = client

    def request(self, payload: dict) -> dict:
        response = self._client.request(
            payload.get("method", "GET"),
            payload.get("path", "/"),
            content=payload.get("body") or None,
            headers={"Content-Type": "application/json"},
        )
        return {
            "status": response.status_code,
            "content_type": response.headers.get("content-type", "application/json"),
            "body": response.text,
        }


def frontend_index() -> Path:
    if getattr(sys, "frozen", False):
        # PyInstaller bundle: `build desktop` ships the web build under frontend/.
        base = Path(getattr(sys, "_MEIPASS", Path(sys.executable).parent))
        return base / "frontend" / "index.html"
    return Path(__file__).resolve().parents[3] / "frontend" / "dist" / "index.html"


def run(check: bool = False) -> int:
    prepare_environment()

    from fastapi.testclient import TestClient  # in-process ASGI client, not a server

    from {{ pkg_slug }}_backend.app import app

    with TestClient(app, raise_server_exceptions=False) as client:
        api = Api(client)

        if check:
            health = api.request({"method": "GET", "path": "/api/health"})
            ok = health["status"] == 200
            print(f"desktop check: {'OK' if ok else 'FAILED'} {health}")
            return 0 if ok else 1

        index = frontend_index()
        if not index.exists():
            print(
                f"Web build not found at {index}. Run: {{ cli_name }} build web",
                file=sys.stderr,
            )
            return 1

        import webview  # deferred: needs a GUI toolkit, keep --check headless-safe

        webview.create_window(
            WINDOW_TITLE,
            url=index.as_uri(),
            js_api=api,
            width=1100,
            height=760,
        )
        webview.start()
    return 0


def main() -> None:
    parser = argparse.ArgumentParser(description=f"Run the {WINDOW_TITLE} desktop app.")
    parser.add_argument(
        "--check",
        action="store_true",
        help="Boot the in-process API, hit /api/health, exit (no window).",
    )
    args = parser.parse_args()
    raise SystemExit(run(check=args.check))


if __name__ == "__main__":
    main()
