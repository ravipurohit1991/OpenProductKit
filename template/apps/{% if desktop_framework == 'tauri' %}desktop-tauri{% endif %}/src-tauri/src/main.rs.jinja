// The {{ project_name }} desktop shell (Tauri).
//
// The shell owns no business logic: it spawns the sidecar server (the FastAPI
// backend serving both the API and the built web UI) on a free localhost port,
// waits until it accepts connections, and opens a window on it. One origin,
// no CORS, no custom-protocol quirks. Dev runs the server from source via uv;
// packaged builds run the PyInstaller external binary bundled next to the app.

#![cfg_attr(not(debug_assertions), windows_subsystem = "windows")]

use std::net::{TcpListener, TcpStream};
use std::path::Path;
use std::process::{Child, Command};
use std::sync::Mutex;
use std::time::Duration;

use tauri::Manager;

struct Sidecar(Mutex<Option<Child>>);

fn free_port() -> u16 {
    TcpListener::bind("127.0.0.1:0")
        .expect("bind a free port")
        .local_addr()
        .expect("read local addr")
        .port()
}

fn spawn_server(port: u16) -> std::io::Result<Child> {
    let mut cmd = if cfg!(debug_assertions) {
        // Dev: run from source through uv, from the repo root.
        let tauri_dir = Path::new(env!("CARGO_MANIFEST_DIR")); // apps/desktop-tauri/src-tauri
        let app_dir = tauri_dir.parent().expect("app dir");
        let repo_root = app_dir
            .parent()
            .and_then(Path::parent)
            .expect("repo root");
        let mut cmd = Command::new("uv");
        cmd.arg("run")
            .arg("python")
            .arg(app_dir.join("server.py"))
            .current_dir(repo_root);
        cmd
    } else {
        // Packaged: the external binary sits next to the app executable.
        let exe = std::env::current_exe().expect("current exe");
        let dir = exe.parent().expect("exe dir");
        let name = if cfg!(windows) { "server.exe" } else { "server" };
        Command::new(dir.join(name))
    };
    cmd.arg("--port").arg(port.to_string());
    #[cfg(windows)]
    {
        use std::os::windows::process::CommandExt;
        cmd.creation_flags(0x0800_0000); // CREATE_NO_WINDOW: no console flash
    }
    cmd.spawn()
}

fn wait_ready(port: u16) -> bool {
    // Uvicorn accepts TCP connections once it serves; poll for up to 30s.
    for _ in 0..150 {
        if TcpStream::connect(("127.0.0.1", port)).is_ok() {
            return true;
        }
        std::thread::sleep(Duration::from_millis(200));
    }
    false
}

fn main() {
    tauri::Builder::default()
        .setup(|app| {
            let port = free_port();
            let child = spawn_server(port)?;
            app.manage(Sidecar(Mutex::new(Some(child))));
            if !wait_ready(port) {
                return Err("the sidecar server did not start in time".into());
            }
            let url = format!("http://127.0.0.1:{port}/")
                .parse()
                .expect("valid sidecar url");
            tauri::WebviewWindowBuilder::new(app, "main", tauri::WebviewUrl::External(url))
                .title("{{ project_name }}")
                .inner_size(1100.0, 760.0)
                .build()?;
            Ok(())
        })
        .build(tauri::generate_context!())
        .expect("error while building the tauri application")
        .run(|app, event| {
            if let tauri::RunEvent::Exit = event {
                if let Some(state) = app.try_state::<Sidecar>() {
                    if let Some(mut child) = state.0.lock().expect("sidecar lock").take() {
                        let _ = child.kill();
                    }
                }
            }
        });
}
