[project]
name = "{{ pkg_slug }}-cli"
version = "0.1.0"
description = "Typer CLI and task runner around the core."
requires-python = ">={{ python_version }}"
dependencies = [
    "{{ pkg_slug }}-core",
    "{{ pkg_slug }}-backend",
    "{{ pkg_slug }}-plugin-api",
    "{{ pkg_slug }}-licensing",
    "typer>=0.12",
]

[project.scripts]
{{ cli_name }} = "{{ pkg_slug }}_cli.main:app"

[tool.uv.sources]
"{{ pkg_slug }}-core" = { workspace = true }
"{{ pkg_slug }}-backend" = { workspace = true }
"{{ pkg_slug }}-plugin-api" = { workspace = true }
"{{ pkg_slug }}-licensing" = { workspace = true }

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ pkg_slug }}_cli"]
