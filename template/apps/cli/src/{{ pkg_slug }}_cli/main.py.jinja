{%- if desktop_framework != 'none' %}
def _plugin_bundle_args() -> list[str]:
    """PyInstaller args that carry installed plugins into the frozen build.

    Entry-point discovery inside the bundle needs each plugin's dist-info
    (--copy-metadata) and its module frozen in (--hidden-import) — PyInstaller's
    static analysis cannot see either on its own.
    """
    from importlib import metadata

    args: list[str] = []
    for dist in metadata.distributions():
        plugin_eps = [ep for ep in dist.entry_points if ep.group == ENTRYPOINT_GROUP]
        if not plugin_eps:
            continue
        args += ["--copy-metadata", dist.metadata["Name"]]
        for ep in plugin_eps:
            args += ["--hidden-import", ep.module]
    return args
{%- endif %}


{%- if desktop_framework == 'pywebview' %}
@build_app.command("desktop")
def build_desktop() -> None:
    """Package the desktop app (PyInstaller onedir) into ./dist.

    Bundles the web build and the alembic migrations as data files. Code
    signing / notarization is intentionally out of scope — see the docs.
    """
    code = _run(["pnpm", "-C", "apps/frontend", "build"])
    if code != 0:
        raise typer.Exit(code)
    # Absolute paths: --specpath moves the spec into build/, and PyInstaller
    # resolves relative --add-data paths against the spec, not the cwd.
    root = Path.cwd()
    sep = os.pathsep
    raise typer.Exit(
        _run(
            [
                "uv",
                "run",
                "--group",
                "build",
                "pyinstaller",
                "--noconfirm",
                "--clean",
                "--windowed",
                "--name",
                "{{ project_slug }}",
                "--specpath",
                "build",
                "--add-data",
                f"{root / 'apps' / 'frontend' / 'dist'}{sep}frontend",
                "--add-data",
                f"{root / 'apps' / 'backend' / 'alembic.ini'}{sep}alembic",
                "--add-data",
                f"{root / 'apps' / 'backend' / 'migrations'}{sep}alembic/migrations",
                # migrations/env.py is exec'd at runtime from data files, so
                # static analysis never sees its stdlib imports.
                "--hidden-import",
                "logging.config",
                "--hidden-import",
                "logging.handlers",
                "--collect-all",
                "webview",
                # Installed plugins: metadata + modules, so entry-point
                # discovery keeps working inside the frozen build.
                *_plugin_bundle_args(),
                str(root / "apps" / "desktop" / "src" / "{{ pkg_slug }}_desktop" / "main.py"),
            ]
        )
    )
{%- elif desktop_framework in ('electron', 'tauri') %}
def _build_server_sidecar(*, name: str, entry: str, onefile: bool) -> int:
    """PyInstaller-bundle the backend server (serves API + web UI) into ./dist.

    Uses the same data-file layout as the in-process desktop build: alembic
    config and migrations under `alembic/`, the web build under `frontend/`.
    """
    # Absolute paths: --specpath moves the spec into build/, and PyInstaller
    # resolves relative --add-data paths against the spec, not the cwd.
    root = Path.cwd()
    sep = os.pathsep
    return _run(
        [
            "uv",
            "run",
            "--group",
            "build",
            "pyinstaller",
            "--noconfirm",
            "--clean",
            *(["--onefile"] if onefile else []),
            "--name",
            name,
            "--specpath",
            "build",
            "--add-data",
            f"{root / 'apps' / 'frontend' / 'dist'}{sep}frontend",
            "--add-data",
            f"{root / 'apps' / 'backend' / 'alembic.ini'}{sep}alembic",
            "--add-data",
            f"{root / 'apps' / 'backend' / 'migrations'}{sep}alembic/migrations",
            # migrations/env.py is exec'd at runtime from data files, so
            # static analysis never sees its stdlib imports.
            "--hidden-import",
            "logging.config",
            "--hidden-import",
            "logging.handlers",
            # Installed plugins: metadata + modules, so entry-point discovery
            # keeps working inside the frozen build.
            *_plugin_bundle_args(),
            str(root / entry),
        ]
    )
{%- endif %}
