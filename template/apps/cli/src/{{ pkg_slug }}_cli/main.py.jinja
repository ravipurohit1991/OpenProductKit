# --- projects -----------------------------------------------------------------


@project_app.command("add")
def project_add(name: str) -> None:
    """Create a project."""
    with _session() as session:
        project = ProjectService(SqlProjectRepository(session)).create(name)
    typer.echo(f"{project.id}  {project.name}")


@project_app.command("list")
def project_list() -> None:
    """List all projects."""
    with _session() as session:
        projects = ProjectService(SqlProjectRepository(session)).list()
    if not projects:
        typer.echo("No projects yet.")
        return
    for project in projects:
        typer.echo(f"{project.id}  {project.name}")


# --- notes --------------------------------------------------------------------


@note_app.command("add")
def note_add(
    project_id: str,
    title: str,
    body: str = typer.Option("", "--body"),
    tag: list[str] = typer.Option(None, "--tag", help="Repeatable."),
) -> None:
    """Add a note to a project."""
    with _session() as session:
        svc = NoteService(SqlNoteRepository(session), SqlProjectRepository(session))
        try:
            note = svc.create(project_id, title, body, tag or [])
        except CoreError as exc:
            typer.echo(str(exc), err=True)
            raise typer.Exit(1) from exc
    tags = f"  [{', '.join(note.tags)}]" if note.tags else ""
    typer.echo(f"{note.id}  {note.title}{tags}")


@note_app.command("list")
def note_list(
    project_id: str = typer.Option(None, "--project"),
    tag: str = typer.Option(None, "--tag"),
    query: str = typer.Option(None, "--q", help="Free-text search."),
) -> None:
    """List/search notes."""
    with _session() as session:
        svc = NoteService(SqlNoteRepository(session), SqlProjectRepository(session))
        notes = svc.search(project_id=project_id, tag=tag, query=query)
    if not notes:
        typer.echo("No matching notes.")
        return
    for note in notes:
        tags = f"  [{', '.join(note.tags)}]" if note.tags else ""
        typer.echo(f"{note.id}  {note.title}{tags}")


# --- plugins ------------------------------------------------------------------


@plugin_app.command("list")
def plugin_list() -> None:
    """List installed plugins and their state."""
    with _session() as session:
        views = build_registry(session).all()
    if not views:
        typer.echo("No plugins installed.")
        return
    for view in views:
        manifest = view.manifest
        state = "on " if view.enabled else "off"
        lock = "" if view.entitled else " (locked)"
        plan = f" plan={manifest.required_plan}" if manifest.required_plan else ""
        typer.echo(f"  [{state}] {manifest.id}  {manifest.name} v{manifest.version}{plan}{lock}")


@plugin_app.command("enable")
def plugin_enable(plugin_id: str) -> None:
    """Enable a plugin."""
    _toggle_plugin(plugin_id, enabled=True)


@plugin_app.command("disable")
def plugin_disable(plugin_id: str) -> None:
    """Disable a plugin."""
    _toggle_plugin(plugin_id, enabled=False)


@plugin_app.command("install")
def plugin_install(path: str) -> None:
    """Install a local plugin package (editable) so its entry point is discovered."""
    raise typer.Exit(_run(["uv", "pip", "install", "-e", path]))


def _toggle_plugin(plugin_id: str, *, enabled: bool) -> None:
    with _session() as session:
        if build_registry(session).get(plugin_id) is None:
            typer.echo(f"Unknown plugin: {plugin_id}", err=True)
            raise typer.Exit(1)
        set_enabled(session, plugin_id, enabled)
    typer.echo(f"{plugin_id} {'enabled' if enabled else 'disabled'}")


# --- licensing ----------------------------------------------------------------


def _read_if_file(value: str) -> str:
    """Accept a raw value or a path to a file containing it (trailing newline ok)."""
    candidate = Path(value)
    try:
        if candidate.is_file():
            return candidate.read_text(encoding="utf-8").strip()
    except OSError:
        pass
    return value.strip()


def _echo_license(info: LicenseInfo) -> None:
    typer.echo(f"  plan:     {info.plan if info.valid else 'free'}")
    typer.echo(f"  valid:    {'yes' if info.valid else 'no'}")
    typer.echo(f"  licensee: {info.licensee or '-'}")
    typer.echo(f"  features: {', '.join(info.features) or '-'}")
    expires = info.expires_at.date().isoformat() if info.expires_at else "never"
    typer.echo(f"  expires:  {expires}")
    typer.echo(f"  source:   {info.source}")
    if info.message:
        typer.echo(f"  note:     {info.message}")


@license_app.command("status")
def license_status() -> None:
    """Show the license the app currently resolves (plan, licensee, expiry)."""
    _echo_license(get_license_provider().info())


@license_app.command("install")
def license_install(token: str = typer.Argument(..., help="Token string or file path.")) -> None:
    """Install a license token into the app's license file."""
    from {{ pkg_slug }}_backend.settings import settings

    dest = Path(settings.license_file)
    dest.write_text(_read_if_file(token) + "\n", encoding="utf-8")
    typer.echo(f"License written to {dest}.")
    typer.echo("Check it with: {{ cli_name }} license status")


@license_app.command("verify")
def license_verify(
    token: str = typer.Argument(..., help="Token string or file path."),
    public_key: str = typer.Option(
        "", "--public-key", help="Raw key or file path; defaults to the app's configured key."
    ),
) -> None:
    """Verify a signed token offline and print its contents (exit 1 if invalid)."""
    from {{ pkg_slug }}_backend.settings import settings

    key = _read_if_file(public_key) if public_key else settings.license_public_key
    info = verify_token(_read_if_file(token), key)
    _echo_license(info)
    if not info.valid:
        raise typer.Exit(1)


# --- licensing: vendor side (you, selling your product) -------------------------


@license_app.command("keygen")
def license_keygen(
    out_dir: str = typer.Option(".", "--out-dir", help="Where to write the key files."),
) -> None:
    """Generate the vendor signing keypair. Run once; keep the private key secret."""
    out = Path(out_dir)
    private_path = out / "license-signing.private"
    public_path = out / "license-signing.public"
    if private_path.exists():
        typer.echo(f"Refusing to overwrite existing {private_path}", err=True)
        raise typer.Exit(1)
    out.mkdir(parents=True, exist_ok=True)
    keys = generate_keypair()
    private_path.write_text(keys.private_key + "\n", encoding="utf-8")
    public_path.write_text(keys.public_key + "\n", encoding="utf-8")
    typer.echo(f"Wrote {private_path}  (SECRET - never commit or ship this)")
    typer.echo(f"Wrote {public_path}")
    typer.echo("")
    typer.echo("Bake the public key into the app so it can verify licenses:")
    typer.echo(f"  APP_LICENSE_PUBLIC_KEY={keys.public_key}")


@license_app.command("issue")
def license_issue(
    licensee: str = typer.Option(..., "--licensee", help="Customer name or email."),
    plan: str = typer.Option("pro", "--plan", help="free, pro or enterprise."),
    days: int = typer.Option(0, "--days", help="Validity in days (0 = perpetual)."),
    feature: list[str] = typer.Option(None, "--feature", help="Repeatable feature flag."),
    key_file: str = typer.Option(
        "license-signing.private", "--key-file", help="Vendor private key from keygen."
    ),
    out: str = typer.Option("", "--out", help="Also write the token to this file."),
) -> None:
    """Sign a license token for a customer with the vendor private key."""
    key_path = Path(key_file)
    if not key_path.is_file():
        typer.echo(
            f"Signing key not found: {key_path} (generate one with: license keygen)", err=True
        )
        raise typer.Exit(1)
    token = issue_token(
        key_path.read_text(encoding="utf-8").strip(),
        licensee=licensee,
        plan=plan,
        features=feature or [],
        valid_days=days or None,
    )
    if out:
        Path(out).write_text(token + "\n", encoding="utf-8")
        typer.echo(f"Wrote {out}")
    typer.echo(token)


# Attach CLI commands contributed by installed, licensed plugins.
_license = get_license_provider()
for _plugin in discover(ENTRYPOINT_GROUP):
    _plugin_cli = _plugin.cli()
    if _plugin_cli is not None and _license.is_entitled(_plugin.manifest.required_plan):
        app.add_typer(_plugin_cli, name=_plugin.manifest.id.replace(".", "-"))


if __name__ == "__main__":
    app()
