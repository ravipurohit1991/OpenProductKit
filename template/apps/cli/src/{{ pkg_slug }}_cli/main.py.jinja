def _session() -> Session:
    upgrade_head()
    return Session(engine)


def _run(cmd: list[str]) -> int:
    """Run an external tool, resolving its path first.

    On Windows, `pnpm`/`npx` are `.CMD` shims that bare `subprocess` cannot find
    without PATHEXT resolution, so we resolve via `shutil.which` up front.
    """
    exe = shutil.which(cmd[0])
    if exe is None:
        typer.echo(f"Required tool not found on PATH: {cmd[0]}", err=True)
        raise typer.Exit(127)
    return subprocess.call([exe, *cmd[1:]])


