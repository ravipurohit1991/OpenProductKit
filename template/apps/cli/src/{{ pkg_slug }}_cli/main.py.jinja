"""The {{ cli_name }} command: a delivery adapter around the core *and* the repo's
task runner and control plane (so there is no Makefile to maintain across
platforms).

Command groups:
  {{ cli_name }} project …   manage projects (core adapter)
  {{ cli_name }} note …      manage notes (core adapter)
  {{ cli_name }} db …        database migrations (Alembic)
  {{ cli_name }} build …     build artifacts
plus dev / doctor / info / test / lint / fmt / openapi / gen / version.
"""

from __future__ import annotations

import shutil
import subprocess
import sys

import typer
from sqlmodel import Session

from {{ pkg_slug }}_backend.adapters.db.engine import engine
from {{ pkg_slug }}_backend.adapters.db.plugin_state import set_enabled
from {{ pkg_slug }}_backend.adapters.db.repository import (
    SqlNoteRepository,
    SqlProjectRepository,
)
from {{ pkg_slug }}_backend.db import downgrade, make_revision, upgrade_head
from {{ pkg_slug }}_backend.plugins import build_registry
from {{ pkg_slug }}_core.errors import CoreError
from {{ pkg_slug }}_core.services.notes import NoteService
from {{ pkg_slug }}_core.services.projects import ProjectService
from {{ pkg_slug }}_licensing import LocalDevLicenseProvider
from {{ pkg_slug }}_plugin_api import ENTRYPOINT_GROUP, discover

app = typer.Typer(
    help="{{ project_name }} developer CLI, task runner and control plane.",
    no_args_is_help=True,
    add_completion=False,
)

project_app = typer.Typer(help="Manage projects.", no_args_is_help=True)
note_app = typer.Typer(help="Manage notes.", no_args_is_help=True)
db_app = typer.Typer(help="Database migrations.", no_args_is_help=True)
build_app = typer.Typer(help="Build artifacts.", no_args_is_help=True)
docs_app = typer.Typer(help="Documentation site.", no_args_is_help=True)
plugin_app = typer.Typer(help="Manage extensions / plugins.", no_args_is_help=True)
app.add_typer(project_app, name="project")
app.add_typer(note_app, name="note")
app.add_typer(db_app, name="db")
app.add_typer(build_app, name="build")
app.add_typer(docs_app, name="docs")
app.add_typer(plugin_app, name="plugin")


def _session() -> Session:
    upgrade_head()
    return Session(engine)


def _run(cmd: list[str]) -> int:
    """Run an external tool, resolving its path first.

    On Windows, `pnpm`/`npx` are `.CMD` shims that bare `subprocess` cannot find
    without PATHEXT resolution, so we resolve via `shutil.which` up front.
    """
    exe = shutil.which(cmd[0])
    if exe is None:
        typer.echo(f"Required tool not found on PATH: {cmd[0]}", err=True)
        raise typer.Exit(127)
    return subprocess.call([exe, *cmd[1:]])


# --- smoke test / info --------------------------------------------------------


@app.command()
def hello(name: str = typer.Argument("world")) -> None:
    """Print a greeting — the simplest end-to-end smoke test."""
    typer.echo(f"Hello, {name}! {{ project_name }} is alive.")


@app.command()
def info() -> None:
    """Show project and environment information."""
    from {{ pkg_slug }}_backend.settings import settings

    typer.echo("{{ project_name }}")
    typer.echo(f"  python:   {sys.version.split()[0]}")
    typer.echo(f"  database: {settings.database_url}")
    typer.echo(f"  node:     {shutil.which('node') or 'not found'}")
    typer.echo(f"  pnpm:     {shutil.which('pnpm') or 'not found'}")


@app.command()
def version() -> None:
    """Print the CLI version."""
    from importlib.metadata import version as _version

    typer.echo(_version("{{ pkg_slug }}-cli"))


# --- dev / quality ------------------------------------------------------------


@app.command()
def dev(port: int = 8000, reload: bool = True) -> None:
    """Run the backend dev server (FastAPI via uvicorn)."""
    import uvicorn

    uvicorn.run(
        "{{ pkg_slug }}_backend.app:app",
        host="127.0.0.1",
        port=port,
        reload=reload,
    )


@app.command()
def doctor() -> None:
    """Check that the expected local toolchain is present."""
    required = {"python": sys.executable, "node": shutil.which("node")}
    optional = {"pnpm": shutil.which("pnpm"), "docker": shutil.which("docker")}

    healthy = True
    typer.echo("Required:")
    for name, value in required.items():
        ok = bool(value)
        healthy = healthy and ok
        typer.echo(f"  [{'OK' if ok else '--'}] {name}: {value or 'NOT FOUND'}")
    typer.echo("Optional:")
    for name, value in optional.items():
        typer.echo(f"  [{'OK' if value else '  '}] {name}: {value or 'not found'}")

    if not healthy:
        typer.echo("\nSome required tools are missing.", err=True)
        raise typer.Exit(1)
    typer.echo("\nAll good.")


@app.command()
def test() -> None:
    """Run the Python test suite."""
    raise typer.Exit(_run(["uv", "run", "pytest"]))


@app.command()
def lint() -> None:
    """Run ruff over the workspace."""
    raise typer.Exit(_run(["uv", "run", "ruff", "check", "."]))


@app.command()
def fmt() -> None:
    """Format the workspace with ruff."""
    raise typer.Exit(_run(["uv", "run", "ruff", "format", "."]))


@app.command()
def openapi(output: str = typer.Option("openapi.json", "--output", "-o")) -> None:
    """Export the backend OpenAPI schema to a JSON file."""
    import json

    from {{ pkg_slug }}_backend.app import app as backend_app

    schema = backend_app.openapi()
    with open(output, "w", encoding="utf-8") as fh:
        json.dump(schema, fh, indent=2)
    typer.echo(f"Wrote {output}")


@app.command()
def gen() -> None:
    """Regenerate the typed frontend client from the backend OpenAPI schema."""
    openapi(output="openapi.json")
    code = _run(["pnpm", "-C", "apps/frontend", "gen:client"])
    if code == 0:
        typer.echo("Client regenerated at apps/frontend/src/client/schema.d.ts")
    raise typer.Exit(code)


# --- database -----------------------------------------------------------------


@db_app.command("migrate")
def db_migrate() -> None:
    """Apply all pending migrations (upgrade to head)."""
    upgrade_head()
    typer.echo("Database is at head.")


@db_app.command("revision")
def db_revision(
    message: str = typer.Option(..., "--message", "-m", help="Migration message."),
) -> None:
    """Autogenerate a new migration from model changes."""
    make_revision(message)
    typer.echo("Created migration under apps/backend/migrations/versions/.")


@db_app.command("downgrade")
def db_downgrade(revision: str = typer.Argument("-1")) -> None:
    """Revert migrations (default: one step)."""
    downgrade(revision)
    typer.echo(f"Downgraded to {revision}.")


@db_app.command("reset")
def db_reset() -> None:
    """Drop everything and re-apply all migrations."""
    downgrade("base")
    upgrade_head()
    typer.echo("Database reset to a fresh head.")


# --- build --------------------------------------------------------------------


@build_app.command("web")
def build_web() -> None:
    """Build the production web bundle."""
    raise typer.Exit(_run(["pnpm", "-C", "apps/frontend", "build"]))


# --- docs ---------------------------------------------------------------------


@docs_app.command("serve")
def docs_serve(port: int = 8001) -> None:
    """Serve the docs site locally (installs the docs group on demand)."""
    raise typer.Exit(
        _run(["uv", "run", "--group", "docs", "mkdocs", "serve", "-a", f"127.0.0.1:{port}"])
    )


@docs_app.command("build")
def docs_build() -> None:
    """Build the static docs site into ./site."""
    raise typer.Exit(_run(["uv", "run", "--group", "docs", "mkdocs", "build"]))


# --- projects -----------------------------------------------------------------


@project_app.command("add")
def project_add(name: str) -> None:
    """Create a project."""
    with _session() as session:
        project = ProjectService(SqlProjectRepository(session)).create(name)
    typer.echo(f"{project.id}  {project.name}")


@project_app.command("list")
def project_list() -> None:
    """List all projects."""
    with _session() as session:
        projects = ProjectService(SqlProjectRepository(session)).list()
    if not projects:
        typer.echo("No projects yet.")
        return
    for project in projects:
        typer.echo(f"{project.id}  {project.name}")


# --- notes --------------------------------------------------------------------


@note_app.command("add")
def note_add(
    project_id: str,
    title: str,
    body: str = typer.Option("", "--body"),
    tag: list[str] = typer.Option(None, "--tag", help="Repeatable."),
) -> None:
    """Add a note to a project."""
    with _session() as session:
        svc = NoteService(SqlNoteRepository(session), SqlProjectRepository(session))
        try:
            note = svc.create(project_id, title, body, tag or [])
        except CoreError as exc:
            typer.echo(str(exc), err=True)
            raise typer.Exit(1) from exc
    tags = f"  [{', '.join(note.tags)}]" if note.tags else ""
    typer.echo(f"{note.id}  {note.title}{tags}")


@note_app.command("list")
def note_list(
    project_id: str = typer.Option(None, "--project"),
    tag: str = typer.Option(None, "--tag"),
    query: str = typer.Option(None, "--q", help="Free-text search."),
) -> None:
    """List/search notes."""
    with _session() as session:
        svc = NoteService(SqlNoteRepository(session), SqlProjectRepository(session))
        notes = svc.search(project_id=project_id, tag=tag, query=query)
    if not notes:
        typer.echo("No matching notes.")
        return
    for note in notes:
        tags = f"  [{', '.join(note.tags)}]" if note.tags else ""
        typer.echo(f"{note.id}  {note.title}{tags}")


# --- plugins ------------------------------------------------------------------


@plugin_app.command("list")
def plugin_list() -> None:
    """List installed plugins and their state."""
    with _session() as session:
        views = build_registry(session).all()
    if not views:
        typer.echo("No plugins installed.")
        return
    for view in views:
        manifest = view.manifest
        state = "on " if view.enabled else "off"
        lock = "" if view.entitled else " (locked)"
        plan = f" plan={manifest.required_plan}" if manifest.required_plan else ""
        typer.echo(f"  [{state}] {manifest.id}  {manifest.name} v{manifest.version}{plan}{lock}")


@plugin_app.command("enable")
def plugin_enable(plugin_id: str) -> None:
    """Enable a plugin."""
    _toggle_plugin(plugin_id, enabled=True)


@plugin_app.command("disable")
def plugin_disable(plugin_id: str) -> None:
    """Disable a plugin."""
    _toggle_plugin(plugin_id, enabled=False)


@plugin_app.command("install")
def plugin_install(path: str) -> None:
    """Install a local plugin package (editable) so its entry point is discovered."""
    raise typer.Exit(_run(["uv", "pip", "install", "-e", path]))


def _toggle_plugin(plugin_id: str, *, enabled: bool) -> None:
    with _session() as session:
        if build_registry(session).get(plugin_id) is None:
            typer.echo(f"Unknown plugin: {plugin_id}", err=True)
            raise typer.Exit(1)
        set_enabled(session, plugin_id, enabled)
    typer.echo(f"{plugin_id} {'enabled' if enabled else 'disabled'}")


# Attach CLI commands contributed by installed, licensed plugins.
_license = LocalDevLicenseProvider()
for _plugin in discover(ENTRYPOINT_GROUP):
    _plugin_cli = _plugin.cli()
    if _plugin_cli is not None and _license.is_entitled(_plugin.manifest.required_plan):
        app.add_typer(_plugin_cli, name=_plugin.manifest.id.replace(".", "-"))


if __name__ == "__main__":
    app()
