@user_app.command("remove")
def user_remove(email: str = typer.Argument(..., help="Email of the account to delete.")) -> None:
    """Delete a user account (and its sessions)."""
    from sqlmodel import delete, select

    from {{ pkg_slug }}_backend.adapters.db.models import AuthSessionRow, UserRow

    with _session() as session:
        user = session.exec(select(UserRow).where(UserRow.email == email.lower())).first()
        if user is None:
            typer.echo(f"No user with email: {email}", err=True)
            raise typer.Exit(1)
        session.exec(delete(AuthSessionRow).where(AuthSessionRow.user_id == user.id))
        session.delete(user)
        session.commit()
    typer.echo(f"Removed {email}.")


@user_app.command("passwd")
def user_passwd(
    email: str = typer.Argument(..., help="Email of the account."),
    password: str = typer.Option(
        None, "--password", help="Set non-interactively; omit to be prompted."
    ),
) -> None:
    """Reset a user's password (also revokes their open sessions)."""
    from sqlmodel import delete, select

    from {{ pkg_slug }}_backend.adapters.db.models import AuthSessionRow, UserRow
    from {{ pkg_slug }}_backend.auth import hash_password

    if password is None:
        password = typer.prompt("New password", hide_input=True, confirmation_prompt=True)
    if len(password) < 8:
        typer.echo("Password must be at least 8 characters.", err=True)
        raise typer.Exit(1)
    with _session() as session:
        user = session.exec(select(UserRow).where(UserRow.email == email.lower())).first()
        if user is None:
            typer.echo(f"No user with email: {email}", err=True)
            raise typer.Exit(1)
        user.password_hash = hash_password(password)
        session.add(user)
        session.exec(delete(AuthSessionRow).where(AuthSessionRow.user_id == user.id))
        session.commit()
    typer.echo(f"Password updated for {email}.")


