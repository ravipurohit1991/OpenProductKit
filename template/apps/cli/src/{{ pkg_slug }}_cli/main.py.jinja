@user_app.command("list")
def user_list() -> None:
    """List user accounts."""
    from sqlmodel import select

    from {{ pkg_slug }}_backend.adapters.db.models import UserRow

    with _session() as session:
        users = session.exec(select(UserRow).order_by(UserRow.created_at)).all()
    if not users:
