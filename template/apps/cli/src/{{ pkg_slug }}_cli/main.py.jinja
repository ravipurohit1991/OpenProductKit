{%- elif desktop_framework == 'tauri' %}


def _rust_host_triple() -> str:
    """Ask rustc for the host target triple (tauri names sidecars with it)."""
    rustc = shutil.which("rustc")
    if rustc is None:
        typer.echo("Rust toolchain not found — install it from https://rustup.rs", err=True)
        raise typer.Exit(127)
    for line in subprocess.check_output([rustc, "-Vv"], text=True).splitlines():
        if line.startswith("host:"):
            return line.split()[1]
    typer.echo("Could not determine the Rust host triple from `rustc -Vv`.", err=True)
    raise typer.Exit(1)


@build_app.command("desktop")
def build_desktop() -> None:
    """Package the desktop app: PyInstaller server sidecar + `tauri build`.

    Needs the Rust toolchain. Code signing / notarization is intentionally out
    of scope — see the docs.
    """
    code = _run(["pnpm", "-C", "apps/frontend", "build"])
    if code != 0:
        raise typer.Exit(code)
    code = _build_server_sidecar(
        name="server", entry="apps/desktop-tauri/server.py", onefile=True
    )
    if code != 0:
        raise typer.Exit(code)
    # Tauri bundles "external binaries" by target triple from src-tauri/binaries.
    exe = ".exe" if os.name == "nt" else ""
    sidecar = Path("apps/desktop-tauri/src-tauri/binaries") / f"server-{_rust_host_triple()}{exe}"
    sidecar.parent.mkdir(parents=True, exist_ok=True)
    shutil.copy2(Path("dist") / f"server{exe}", sidecar)
    # The overlay config adds the sidecar as an external binary; it lives
    # outside the base config so `tauri dev` works before any build.
    raise typer.Exit(
        _run(
            [
                "pnpm",
                "-C",
                "apps/desktop-tauri",
                "tauri",
                "build",
                "--config",
                "src-tauri/tauri.bundle.conf.json",
            ]
        )
    )
{%- endif %}


