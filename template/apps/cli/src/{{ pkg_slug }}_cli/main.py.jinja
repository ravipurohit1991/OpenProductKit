@app.command()
def openapi(output: str = typer.Option("openapi.json", "--output", "-o")) -> None:
    """Export the backend OpenAPI schema to a JSON file."""
    import json

    from {{ pkg_slug }}_backend.app import app as backend_app

    schema = backend_app.openapi()
    with open(output, "w", encoding="utf-8") as fh:
        json.dump(schema, fh, indent=2)
    typer.echo(f"Wrote {output}")


@app.command()
def gen(
    check: bool = typer.Option(
        False, "--check", help="Verify the committed client matches the API; write nothing."
    ),
) -> None:
    """Regenerate the typed frontend client from the backend OpenAPI schema."""
    if check:
        raise typer.Exit(_gen_check())
    openapi(output="openapi.json")
    code = _run(["pnpm", "-C", "apps/frontend", "gen:client"])
    if code == 0:
        typer.echo("Client regenerated at apps/frontend/src/client/schema.d.ts")
    raise typer.Exit(code)


def _gen_check() -> int:
    """Drift gate: regenerate the client into build/ and diff the committed one.

    Stable because openapi-typescript is pinned exactly in package.json — the
    original blocker for this gate was format drift across its minor versions.
    """
    build_dir = Path("build")
    build_dir.mkdir(exist_ok=True)
    schema_json = build_dir / "openapi.gen-check.json"
    schema_dts = build_dir / "schema.gen-check.d.ts"
    openapi(output=str(schema_json))
    code = _run(
        [
            "pnpm",
            "-C",
            "apps/frontend",
            "exec",
            "openapi-typescript",
            str(Path("..", "..") / schema_json),
            "-o",
            str(Path("..", "..") / schema_dts),
        ]
    )
    if code != 0:
        return code
    committed = Path("apps/frontend/src/client/schema.d.ts")
    fresh_text = schema_dts.read_text(encoding="utf-8").replace("\r\n", "\n")
    committed_text = (
        committed.read_text(encoding="utf-8").replace("\r\n", "\n")
        if committed.is_file()
        else ""
    )
    if fresh_text != committed_text:
        typer.echo("Generated client is out of date with the backend API.", err=True)
        typer.echo("Fix it with: {{ cli_name }} gen  (then commit the result)", err=True)
        return 1
    typer.echo("Generated client is in sync with the backend API.")
    return 0


