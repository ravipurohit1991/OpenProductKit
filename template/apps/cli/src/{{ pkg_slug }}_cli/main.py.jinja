@stack_app.command("share")
def stack_share() -> None:
    """Start the stack plus a Cloudflare quick tunnel and print the public URL.

    The URL is a throwaway trycloudflare.com address for demos and testing on
    other devices — anyone holding the link reaches your local stack until you
    run `{{ cli_name }} stack down`.
    """
    import re
    import time

    code = _run(["docker", "compose", "--profile", "share", "up", "-d", "--build"])
    if code != 0:
        raise typer.Exit(code)
    typer.echo("Waiting for the tunnel URL…")
    docker = shutil.which("docker")
    for _ in range(30):
        logs = subprocess.run(
            [docker, "compose", "logs", "tunnel", "--no-color"],
            capture_output=True,
            text=True,
        )
        match = re.search(r"https://[a-z0-9-]+\.trycloudflare\.com", logs.stdout + logs.stderr)
        if match:
            typer.echo("")
            typer.echo(f"Public URL: {match.group(0)}")
            typer.echo("Stop sharing with: {{ cli_name }} stack down")
            return
        time.sleep(2)
    typer.echo("Tunnel URL not visible yet — check: docker compose logs tunnel", err=True)
    raise typer.Exit(1)
