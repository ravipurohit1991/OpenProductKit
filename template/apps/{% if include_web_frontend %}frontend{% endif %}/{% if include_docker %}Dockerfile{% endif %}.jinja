# Builds the web UI and serves it with nginx, proxying /api to the backend
# service. Build from the repo root: docker compose build web
FROM node:22-alpine AS build

WORKDIR /app
COPY . .
RUN corepack enable && pnpm install && pnpm -C apps/frontend build

FROM nginx:1.27-alpine
COPY apps/frontend/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/apps/frontend/dist /usr/share/nginx/html
EXPOSE 80
