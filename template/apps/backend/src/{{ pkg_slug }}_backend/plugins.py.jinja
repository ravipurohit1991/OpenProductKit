"""Plugin wiring for the backend.

Discovery (entry points) needs no database, so plugin routers are mounted at app
construction. Each router is gated by a per-request dependency that checks both
the plugin's persisted enabled state *and* its license entitlement — so toggling
a plugin in the manager or unlocking it in the marketplace takes effect
immediately, no restart. A disabled plugin 404s; a locked plugin 403s with the
same structured detail as `require_plan`, which the frontend renders as a
LockedFeatureCard.
"""

from __future__ import annotations

from functools import lru_cache

from fastapi import Depends, FastAPI, HTTPException
from sqlmodel import Session

from {{ pkg_slug }}_plugin_api import ENTRYPOINT_GROUP, Plugin, PluginRegistry, discover

from . import licensing
from .adapters.db.plugin_state import get_enabled_map
from .api.deps import SessionDep


@lru_cache
def discovered_plugins() -> tuple[Plugin, ...]:
    return tuple(discover(ENTRYPOINT_GROUP))


def build_registry(session: Session) -> PluginRegistry:
    enabled = get_enabled_map(session)
    license_provider = licensing.get_license_provider()
    return PluginRegistry(
        discovered_plugins(),
        is_enabled=lambda plugin_id: enabled.get(plugin_id, True),  # enabled by default
        is_entitled=lambda manifest: license_provider.is_entitled(manifest.required_plan),
    )


def _require_active(plugin_id: str, required_plan: str | None):
    def dependency(session: SessionDep) -> None:
        if not get_enabled_map(session).get(plugin_id, True):
            raise HTTPException(status_code=404, detail=f"Plugin '{plugin_id}' is disabled")
        provider = licensing.get_license_provider()
        if not provider.is_entitled(required_plan):
            raise HTTPException(
                status_code=403,
                detail={
                    "error": "license_required",
                    "current_plan": provider.current_plan(),
                    "required_plan": required_plan,
                    "plugin_id": plugin_id,
                },
            )

    return dependency


# Plugin ids whose routers are already mounted on the app — so a runtime
# install (marketplace) can mount only what is new instead of double-mounting.
_mounted: set[str] = set()


def _mount(app: FastAPI, plugin: Plugin) -> None:
    router = plugin.backend_router()
    manifest = plugin.manifest
    _mounted.add(manifest.id)
    if router is None:
        return
    app.include_router(
        router,
        dependencies=[Depends(_require_active(manifest.id, manifest.required_plan))],
    )


def mount_plugin_routers(app: FastAPI) -> None:
    for plugin in discovered_plugins():
        _mount(app, plugin)


def rescan_and_mount_new(app: FastAPI) -> list[str]:
    """Re-discover entry points (after a runtime install) and mount newcomers.

    FastAPI routing is a live list, so routers can be added while serving.
    Returns the ids of newly mounted plugins.
    """
    import importlib

    importlib.invalidate_caches()
    discovered_plugins.cache_clear()
    new_ids: list[str] = []
    for plugin in discovered_plugins():
        if plugin.manifest.id not in _mounted:
            _mount(app, plugin)
            new_ids.append(plugin.manifest.id)
    return new_ids
