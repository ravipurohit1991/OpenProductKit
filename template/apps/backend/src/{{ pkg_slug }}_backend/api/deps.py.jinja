"""FastAPI dependency wiring: build services backed by the SQL repositories.

Uses `Annotated` dependencies (the modern FastAPI idiom) so the wiring is
reusable and lint-clean.
"""

from __future__ import annotations

from typing import Annotated

from fastapi import Depends
from sqlmodel import Session

from {{ pkg_slug }}_core.services.notes import NoteService
from {{ pkg_slug }}_core.services.projects import ProjectService

from ..adapters.db.engine import get_session
from ..adapters.db.repository import SqlNoteRepository, SqlProjectRepository

SessionDep = Annotated[Session, Depends(get_session)]

# [demo] SessionDep above is framework. The service wiring below belongs to the
# Resource Vault sample domain — replace it with wiring for your own services.


def get_project_service(session: SessionDep) -> ProjectService:
    return ProjectService(SqlProjectRepository(session))


def get_note_service(session: SessionDep) -> NoteService:
    return NoteService(SqlNoteRepository(session), SqlProjectRepository(session))


ProjectServiceDep = Annotated[ProjectService, Depends(get_project_service)]
NoteServiceDep = Annotated[NoteService, Depends(get_note_service)]
