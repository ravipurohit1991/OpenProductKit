"""The plugin manager API: list installed plugins and toggle them."""

from __future__ import annotations

from fastapi import APIRouter, Depends, HTTPException
from pydantic import BaseModel

from ...adapters.db.plugin_state import set_enabled
from ...auth import require_admin
from ...plugins import build_registry
from ..deps import SessionDep

router = APIRouter(prefix="/api/plugins", tags=["plugins"])


class PluginOut(BaseModel):
    id: str
    name: str
    version: str
    description: str
    enabled: bool
    entitled: bool
    active: bool
    required_plan: str | None
    permissions: list[str]
    health: str
    health_message: str


def _to_out(view) -> PluginOut:
    manifest = view.manifest
    status = view.plugin.health()
    return PluginOut(
        id=manifest.id,
        name=manifest.name,
        version=manifest.version,
        description=manifest.description,
        enabled=view.enabled,
        entitled=view.entitled,
        active=view.active,
        required_plan=manifest.required_plan,
        permissions=list(manifest.permissions),
        health=status.level.value,
        health_message=status.message,
    )


@router.get("", response_model=list[PluginOut])
def list_plugins(session: SessionDep) -> list[PluginOut]:
    return [_to_out(v) for v in build_registry(session).all()]


@router.post(
    "/{plugin_id}/enable", response_model=PluginOut, dependencies=[Depends(require_admin)]
)
def enable_plugin(plugin_id: str, session: SessionDep) -> PluginOut:
    return _set_state(session, plugin_id, enabled=True)


@router.post(
    "/{plugin_id}/disable", response_model=PluginOut, dependencies=[Depends(require_admin)]
)
def disable_plugin(plugin_id: str, session: SessionDep) -> PluginOut:
    return _set_state(session, plugin_id, enabled=False)


def _set_state(session: SessionDep, plugin_id: str, *, enabled: bool) -> PluginOut:
    if build_registry(session).get(plugin_id) is None:
        raise HTTPException(status_code=404, detail=f"Unknown plugin: {plugin_id}")
    set_enabled(session, plugin_id, enabled)
    return _to_out(build_registry(session).get(plugin_id))
