"""The marketplace API: browse available extensions and unlock paid ones.

The marketplace merges two sources into one list:

- **installed plugins** — discovered via entry points (same data as /api/plugins)
- **the catalog** — extensions the vendor offers but the install may not have
  yet, read from `marketplace/catalog.json` (or APP_MARKETPLACE_URL when set)

Unlocking is licensing, not payments: POST /unlock takes a signed license token
(bought on your website, sent by email — however you sell), verifies it offline
against the vendor public key, persists it, and every gate in the app re-reads
entitlements immediately. Wire a payment provider later and have its webhook
call `{{ cli_name }} license issue` — the app side is already done.
"""

from __future__ import annotations

import json
import shutil
import subprocess
import sys
import urllib.request
from pathlib import Path

from fastapi import APIRouter, Depends, HTTPException, Request
from pydantic import BaseModel

from {{ pkg_slug }}_licensing import verify_token

from ... import licensing
from ...auth import require_admin
from ...plugins import build_registry, rescan_and_mount_new
from ...settings import settings
from ..deps import SessionDep

router = APIRouter(prefix="/api/marketplace", tags=["marketplace"])


class MarketplaceItemOut(BaseModel):
    id: str
    name: str
    version: str
    description: str
    required_plan: str | None
    homepage: str = ""
    #: Shell command that installs the extension, shown for catalog-only items.
    install_hint: str = ""
    #: pip requirement (or local path) the app can install at runtime.
    package: str = ""
    #: True when this install can be done from the running app right now
    #: (package present, APP_MARKETPLACE_ALLOW_INSTALL on, not a frozen build).
    installable: bool = False
    installed: bool
    enabled: bool
    entitled: bool
    active: bool
    source: str  # "installed" | "catalog"


class UnlockIn(BaseModel):
    token: str


class UnlockOut(BaseModel):
    plan: str
    licensee: str
    features: list[str]
    message: str


def _load_catalog() -> list[dict]:
    """Read the catalog from the vendor URL or the local file; never raise."""
    if settings.marketplace_url:
        try:
            with urllib.request.urlopen(settings.marketplace_url, timeout=5) as resp:  # noqa: S310
                return json.load(resp).get("items", [])
        except (OSError, ValueError):
            return []
    path = Path(settings.marketplace_catalog)
    if not path.is_file():
        return []
    try:
        return json.loads(path.read_text(encoding="utf-8")).get("items", [])
    except (OSError, ValueError):
        return []


@router.get("", response_model=list[MarketplaceItemOut])
def list_marketplace(session: SessionDep) -> list[MarketplaceItemOut]:
    catalog = {str(item.get("id", "")): item for item in _load_catalog() if item.get("id")}
    provider = licensing.get_license_provider()

    items: list[MarketplaceItemOut] = []
    for view in build_registry(session).all():
        manifest = view.manifest
        extra = catalog.pop(manifest.id, {})
        items.append(
            MarketplaceItemOut(
                id=manifest.id,
                name=manifest.name,
                version=manifest.version,
                description=manifest.description,
                required_plan=manifest.required_plan,
                homepage=str(extra.get("homepage", "")),
                installed=True,
                enabled=view.enabled,
                entitled=view.entitled,
                active=view.active,
                source="installed",
            )
        )
    for item in catalog.values():
        required_plan = item.get("required_plan") or None
        package = str(item.get("package", "")).strip()
        items.append(
            MarketplaceItemOut(
                id=str(item["id"]),
                name=str(item.get("name", item["id"])),
                version=str(item.get("version", "")),
                description=str(item.get("description", "")),
                required_plan=required_plan,
                homepage=str(item.get("homepage", "")),
                install_hint=str(item.get("install_hint", "")),
                package=package,
                installable=bool(package) and _runtime_install_available(),
                installed=False,
                enabled=False,
                entitled=provider.is_entitled(required_plan),
                active=False,
                source="catalog",
            )
        )
    return sorted(items, key=lambda item: item.id)


# --- runtime install ------------------------------------------------------------


class InstallIn(BaseModel):
    id: str


class InstallOut(BaseModel):
    id: str
    installed: bool
    #: Plugin ids whose routes were mounted live as a result of this install.
    mounted: list[str]
    message: str


def _runtime_install_available() -> bool:
    return settings.marketplace_allow_install and not getattr(sys, "frozen", False)


def pip_install(requirement: str) -> tuple[bool, str]:
    """Install a package into the running environment; prefer uv, else pip.

    `--python sys.executable` pins uv to this exact interpreter, so the install
    lands in the venv the app is actually running from.
    """
    uv = shutil.which("uv")
    if uv:
        cmd = [uv, "pip", "install", "--python", sys.executable, requirement]
    else:
        cmd = [sys.executable, "-m", "pip", "install", requirement]
    try:
        proc = subprocess.run(cmd, capture_output=True, text=True, timeout=600)
    except subprocess.TimeoutExpired:
        return False, "Install timed out after 10 minutes."
    if proc.returncode != 0:
        tail = (proc.stderr or proc.stdout or "unknown error").strip().splitlines()[-8:]
        return False, "\n".join(tail)
    return True, ""


def find_catalog_item(item_id: str) -> dict | None:
    return next(
        (item for item in _load_catalog() if str(item.get("id", "")) == item_id), None
    )


@router.post("/install", response_model=InstallOut, dependencies=[Depends(require_admin)])
def install(payload: InstallIn, request: Request, session: SessionDep) -> InstallOut:
    """Install a catalog extension into the running app — no restart.

    Installing executes the package's code in this environment, so it is opt-in
    (APP_MARKETPLACE_ALLOW_INSTALL), admin-only when auth is on, and should only
    be enabled where the catalog is vendor-controlled.
    """
    if getattr(sys, "frozen", False):
        raise HTTPException(
            status_code=400,
            detail="This is a packaged desktop build — extensions are bundled at build time.",
        )
    if not settings.marketplace_allow_install:
        raise HTTPException(
            status_code=403,
            detail="Runtime install is disabled. Set APP_MARKETPLACE_ALLOW_INSTALL=true.",
        )
    item = find_catalog_item(payload.id)
    if item is None:
        raise HTTPException(status_code=404, detail=f"Unknown catalog item: {payload.id}")
    requirement = str(item.get("package", "")).strip()
    if not requirement:
        raise HTTPException(
            status_code=400,
            detail="This catalog item has no installable package — follow its install hint.",
        )
    required_plan = item.get("required_plan") or None
    provider = licensing.get_license_provider()
    if not provider.is_entitled(required_plan):
        raise HTTPException(
            status_code=403,
            detail={
                "error": "license_required",
                "current_plan": provider.current_plan(),
                "required_plan": required_plan,
            },
        )
    ok, error = pip_install(requirement)
    if not ok:
        raise HTTPException(status_code=502, detail=f"Install failed: {error}")
    mounted = rescan_and_mount_new(request.app)
    installed = build_registry(session).get(payload.id) is not None
    message = (
        f"'{payload.id}' installed and live — no restart needed."
        if installed
        else f"Package installed, but no plugin advertises id '{payload.id}' — check the catalog."
    )
    return InstallOut(id=payload.id, installed=installed, mounted=mounted, message=message)


@router.post("/unlock", response_model=UnlockOut, dependencies=[Depends(require_admin)])
def unlock(payload: UnlockIn) -> UnlockOut:
    """Verify a signed license token, persist it and apply it immediately."""
    token = payload.token.strip()
    if not token:
        raise HTTPException(status_code=400, detail="Empty license token.")
    info = verify_token(token, settings.license_public_key)
    if not info.valid:
        raise HTTPException(status_code=400, detail=info.message or "Invalid license token.")
    dest = Path(settings.license_file)
    dest.parent.mkdir(parents=True, exist_ok=True)
    dest.write_text(token + "\n", encoding="utf-8")
    # The provider is resolved once and cached; drop the cache so every plan
    # and feature gate sees the new license on the next request.
    licensing.get_license_provider.cache_clear()
    return UnlockOut(
        plan=info.plan,
        licensee=info.licensee,
        features=list(info.features),
        message=f"License for '{info.licensee}' activated ({info.plan} plan).",
    )
