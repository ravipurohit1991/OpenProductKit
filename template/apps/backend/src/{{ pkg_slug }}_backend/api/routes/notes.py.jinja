"""HTTP routes for notes. These are thin: parse/serialize, delegate to the service."""

from __future__ import annotations

from fastapi import APIRouter, HTTPException, Query
from pydantic import BaseModel

from {{ pkg_slug }}_core.domain.note import Note
from {{ pkg_slug }}_core.errors import NoteNotFoundError, ProjectNotFoundError

from ..deps import NoteServiceDep

router = APIRouter(prefix="/api/notes", tags=["notes"])


class NoteIn(BaseModel):
    project_id: str
    title: str
    body: str = ""
    tags: list[str] = []


class NoteOut(BaseModel):
    id: str
    project_id: str
    title: str
    body: str
    tags: list[str]
    created_at: str


def _to_out(note: Note) -> NoteOut:
    return NoteOut(
        id=note.id,
        project_id=note.project_id,
        title=note.title,
        body=note.body,
        tags=list(note.tags),
        created_at=note.created_at.isoformat(),
    )


@router.get("", response_model=list[NoteOut])
def list_notes(
    svc: NoteServiceDep,
    project_id: str | None = Query(default=None),
    tag: str | None = Query(default=None),
    q: str | None = Query(default=None, description="Free-text search"),
) -> list[NoteOut]:
    notes = svc.search(project_id=project_id, tag=tag, query=q)
    return [_to_out(n) for n in notes]


@router.post("", response_model=NoteOut, status_code=201)
def create_note(payload: NoteIn, svc: NoteServiceDep) -> NoteOut:
    try:
        note = svc.create(
            payload.project_id, payload.title, payload.body, payload.tags
        )
    except ProjectNotFoundError as exc:
        raise HTTPException(status_code=404, detail=str(exc)) from exc
    except ValueError as exc:
        raise HTTPException(status_code=422, detail=str(exc)) from exc
    return _to_out(note)


@router.get("/{note_id}", response_model=NoteOut)
def get_note(note_id: str, svc: NoteServiceDep) -> NoteOut:
    try:
        note = svc.get(note_id)
    except NoteNotFoundError as exc:
        raise HTTPException(status_code=404, detail=str(exc)) from exc
    return _to_out(note)
