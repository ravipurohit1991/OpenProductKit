[project]
name = "{{ pkg_slug }}-backend"
version = "0.1.0"
description = "FastAPI HTTP adapter around the core."
requires-python = ">={{ python_version }}"
dependencies = [
    "{{ pkg_slug }}-core",
    "{{ pkg_slug }}-plugin-api",
    "{{ pkg_slug }}-licensing",
{%- if include_ai_saas %}
    "{{ pkg_slug }}-ai-runtime",
    "boto3>=1.35",
    "httpx>=0.27",
    "python-multipart>=0.0.9",
    "stripe>=15,<16",
{%- endif %}
    "fastapi>=0.115",
    "uvicorn[standard]>=0.30",
    "sqlmodel>=0.0.22",
    "pydantic-settings>=2.4",
    "alembic>=1.13",
{%- if database == 'postgres' %}
    "psycopg[binary]>=3.2",
{%- endif %}
{%- if desktop_framework in ('electron', 'tauri') %}
    # Per-user data dir for the desktop sidecar server (see apps/desktop-*/server.py).
    "platformdirs>=4",
{%- endif %}
]

[tool.uv.sources]
"{{ pkg_slug }}-core" = { workspace = true }
"{{ pkg_slug }}-plugin-api" = { workspace = true }
"{{ pkg_slug }}-licensing" = { workspace = true }
{%- if include_ai_saas %}
"{{ pkg_slug }}-ai-runtime" = { workspace = true }
{%- endif %}

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ pkg_slug }}_backend"]
