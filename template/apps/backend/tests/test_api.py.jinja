import pytest
from fastapi.testclient import TestClient

from {{ pkg_slug }}_backend.app import app


@pytest.fixture()
def client():
    # Using TestClient as a context manager triggers the lifespan (init_db).
    with TestClient(app) as c:
        yield c


def test_health(client) -> None:
    resp = client.get("/api/health")
    assert resp.status_code == 200
    assert resp.json() == {"status": "ok"}


def test_create_list_and_get_note(client) -> None:
    created = client.post("/api/notes", json={"title": "First", "body": "hi"})
    assert created.status_code == 201
    note_id = created.json()["id"]

    listing = client.get("/api/notes")
    assert any(n["id"] == note_id for n in listing.json())

    fetched = client.get(f"/api/notes/{note_id}")
    assert fetched.status_code == 200
    assert fetched.json()["title"] == "First"


def test_empty_title_is_rejected(client) -> None:
    resp = client.post("/api/notes", json={"title": "  "})
    assert resp.status_code == 422


def test_missing_note_is_404(client) -> None:
    resp = client.get("/api/notes/nope")
    assert resp.status_code == 404
