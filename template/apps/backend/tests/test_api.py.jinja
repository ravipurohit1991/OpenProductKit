def _make_project(client, name: str) -> str:
    resp = client.post("/api/projects", json={"name": name})
    assert resp.status_code == 201
    return resp.json()["id"]


def test_create_project_and_note_with_tags(client) -> None:
    project_id = _make_project(client, "Research")
    resp = client.post(
        "/api/notes",
        json={
            "project_id": project_id,
            "title": "Read paper",
            "tags": ["ML", "ml", "TODO"],
        },
    )
    assert resp.status_code == 201
    body = resp.json()
    assert body["project_id"] == project_id
    assert body["tags"] == ["ml", "todo"]  # normalized + de-duplicated


def test_note_for_missing_project_is_404(client) -> None:
    resp = client.post(
        "/api/notes", json={"project_id": "nope", "title": "orphan"}
    )
    assert resp.status_code == 404


def test_search_filters(client) -> None:
    a = _make_project(client, "A")
    b = _make_project(client, "B")
    client.post(
        "/api/notes",
        json={"project_id": a, "title": "Alpha", "body": "kittens", "tags": ["cats"]},
    )
    client.post(
        "/api/notes",
        json={"project_id": a, "title": "Beta", "body": "puppies", "tags": ["dogs"]},
    )
    client.post(
        "/api/notes", json={"project_id": b, "title": "Gamma", "tags": ["cats"]}
    )

    by_project = client.get("/api/notes", params={"project_id": a}).json()
    assert {n["title"] for n in by_project} == {"Alpha", "Beta"}

    by_tag = client.get("/api/notes", params={"tag": "cats"}).json()
    assert {n["title"] for n in by_tag} == {"Alpha", "Gamma"}

    by_query = client.get("/api/notes", params={"q": "puppies"}).json()
    assert {n["title"] for n in by_query} == {"Beta"}

    combined = client.get(
        "/api/notes", params={"project_id": a, "tag": "cats"}
    ).json()
    assert {n["title"] for n in combined} == {"Alpha"}


def test_empty_title_is_rejected(client) -> None:
    project_id = _make_project(client, "P")
    resp = client.post(
        "/api/notes", json={"project_id": project_id, "title": "  "}
    )
    assert resp.status_code == 422


def test_missing_note_is_404(client) -> None:
    resp = client.get("/api/notes/nope")
    assert resp.status_code == 404


# --- plugins (framework — keep) -------------------------------------------------


def test_example_plugins_are_discovered(client) -> None:
    ids = {p["id"] for p in client.get("/api/plugins").json()}
    assert {"example.basic", "example.cli", "example.paid"} <= ids


def test_basic_plugin_route_reflects_enabled_state(client) -> None:
    assert client.get("/api/ext/basic/ping").json()["pong"] == "ok"

    client.post("/api/plugins/example.basic/disable")
    assert client.get("/api/ext/basic/ping").status_code == 404

    client.post("/api/plugins/example.basic/enable")
    assert client.get("/api/ext/basic/ping").status_code == 200


def test_paid_plugin_is_entitled_by_dev_license(client) -> None:
    paid = next(p for p in client.get("/api/plugins").json() if p["id"] == "example.paid")
    assert paid["required_plan"] == "pro"
    assert paid["entitled"] is True
    # Its license-gated route is mounted and works.
    assert client.get("/api/ext/paid/summary").status_code == 200


def test_toggling_unknown_plugin_is_404(client) -> None:
    assert client.post("/api/plugins/nope/enable").status_code == 404
