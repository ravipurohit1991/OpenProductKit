import pytest
from fastapi.testclient import TestClient

from {{ pkg_slug }}_backend import licensing
from {{ pkg_slug }}_backend.app import app
from {{ pkg_slug }}_backend.settings import settings
from {{ pkg_slug }}_licensing import LocalDevLicenseProvider, generate_keypair, issue_token


@pytest.fixture()
def client():
    with TestClient(app) as c:
        yield c


@pytest.fixture()
def fresh_provider_cache():
    """Unlock swaps the resolved provider; keep the cache isolated per test."""
    licensing.get_license_provider.cache_clear()
    yield
    licensing.get_license_provider.cache_clear()


def test_marketplace_lists_installed_and_catalog_items(client, monkeypatch, tmp_path) -> None:
    catalog = tmp_path / "catalog.json"
    catalog.write_text(
        '{"items": [{"id": "example.reports", "name": "Reports (Pro)",'
        ' "required_plan": "pro", "install_hint": "uv add reports"}]}',
        encoding="utf-8",
    )
    monkeypatch.setattr(settings, "marketplace_catalog", str(catalog))

    items = {item["id"]: item for item in client.get("/api/marketplace").json()}
    # Installed plugins are listed with their live state...
    assert items["example.basic"]["installed"] is True
    assert items["example.basic"]["source"] == "installed"
    # ...and catalog-only items appear as installable.
    assert items["example.reports"]["installed"] is False
    assert items["example.reports"]["source"] == "catalog"
    assert items["example.reports"]["install_hint"] == "uv add reports"


def test_marketplace_survives_a_missing_catalog(client, monkeypatch) -> None:
    monkeypatch.setattr(settings, "marketplace_catalog", "does/not/exist.json")
    resp = client.get("/api/marketplace")
    assert resp.status_code == 200
    assert all(item["installed"] for item in resp.json())


def test_unlock_rejects_a_bad_token(client, fresh_provider_cache, monkeypatch, tmp_path) -> None:
    keys = generate_keypair()
    monkeypatch.setattr(settings, "license_public_key", keys.public_key)
    monkeypatch.setattr(settings, "license_file", str(tmp_path / "license.key"))
    resp = client.post("/api/marketplace/unlock", json={"token": "not-a-token"})
    assert resp.status_code == 400


def test_unlock_installs_token_and_applies_immediately(
    client, fresh_provider_cache, monkeypatch, tmp_path
) -> None:
    keys = generate_keypair()
    license_file = tmp_path / "license.key"
    monkeypatch.setattr(settings, "license_public_key", keys.public_key)
    monkeypatch.setattr(settings, "license_file", str(license_file))
    token = issue_token(keys.private_key, licensee="Acme Corp", plan="pro")

    resp = client.post("/api/marketplace/unlock", json={"token": token})
    assert resp.status_code == 200
    assert resp.json()["plan"] == "pro"
    assert license_file.read_text(encoding="utf-8").strip() == token

    # The new license is live: the resolved provider now reads the token file.
    body = client.get("/api/license").json()
    assert body["plan"] == "pro"
    assert body["licensee"] == "Acme Corp"
    assert body["source"] == "file"


def test_paid_plugin_routes_lock_and_unlock_without_restart(client, monkeypatch) -> None:
    # Entitled (dev stub grants pro): the paid plugin responds.
    assert client.get("/api/ext/paid/summary").status_code == 200
    # Drop to free: the same route is locked per-request, no remount needed.
    monkeypatch.setattr(licensing, "get_license_provider", lambda: LocalDevLicenseProvider("free"))
    resp = client.get("/api/ext/paid/summary")
    assert resp.status_code == 403
    assert resp.json()["detail"]["error"] == "license_required"
