def test_generation_reserves_and_consumes_one_credit_idempotently(client) -> None:
    before = client.get("/api/ai/credits").json()
    assert before["balance"] == settings.ai_trial_credits

    headers = {"Idempotency-Key": "same-request"}
    first = client.post(
        "/api/ai/generations",
        headers=headers,
        json={"prompt": "A clean product photograph", "model": "mock-image"},
    )
    assert first.status_code == 202
    second = client.post(
        "/api/ai/generations",
        headers=headers,
        json={"prompt": "A clean product photograph", "model": "mock-image"},
    )
    assert second.status_code == 202
    assert second.json()["id"] == first.json()["id"]

    jobs = client.get("/api/ai/generations").json()
    assert len(jobs) == 1
    assert jobs[0]["status"] == "succeeded"
    assert jobs[0]["output_url"].startswith("data:image/png;base64,")
    credits = client.get("/api/ai/credits").json()
    assert credits["balance"] == settings.ai_trial_credits - 1
    assert [entry["kind"] for entry in credits["history"]].count("reserve") == 1


def test_trial_credit_account_is_persisted_once() -> None:
    owner_id = "trial-persistence-test"
    with Session(engine) as session:
        assert ai_runtime.credit_balance(session, owner_id) == settings.ai_trial_credits
        assert ai_runtime.credit_balance(session, owner_id) == settings.ai_trial_credits
        grants = session.exec(
            select(CreditLedgerRow).where(CreditLedgerRow.owner_id == owner_id)
        ).all()
        assert [entry.kind for entry in grants] == ["grant"]


def test_generation_input_constraints_are_enforced(client) -> None:
    assert client.post("/api/ai/generations", json={"prompt": ""}).status_code == 422
    assert (
        client.post("/api/ai/generations", json={"prompt": "x" * 4001}).status_code
        == 422
    )


def test_upload_validates_mime_signature(client) -> None:
    bad = client.post(
        "/api/ai/uploads", files={"file": ("fake.png", b"not a png", "image/png")}
    )
    assert bad.status_code == 422

    tiny_png = bytes.fromhex(
        "89504e470d0a1a0a0000000d49484452000000010000000108060000001f15c489"
        "0000000d4944415408d763f8ffff3f030008fc02fe8fede16f0000000049454e44ae426082"
    )
    uploaded = client.post(
        "/api/ai/uploads", files={"file": ("pixel.png", tiny_png, "image/png")}
    )
    assert uploaded.status_code == 201
    fetched = client.get(uploaded.json()["url"])
    assert fetched.status_code == 200
    assert fetched.content == tiny_png


def _stripe_signature(payload: bytes, secret: str) -> str:
    timestamp = int(time.time())
    digest = hmac.new(
        secret.encode(), f"{timestamp}.".encode() + payload, hashlib.sha256
    ).hexdigest()
    return f"t={timestamp},v1={digest}"


def test_stripe_webhook_credit_grant_is_idempotent(client, monkeypatch) -> None:
    monkeypatch.setattr(settings, "stripe_webhook_secret", "whsec_test")
    balance_before = client.get("/api/ai/credits").json()["balance"]
    payload = json.dumps(
        {
            "id": "evt_checkout_once",
            "object": "event",
            "type": "checkout.session.completed",
            "data": {
                "object": {
                    "id": "cs_paid_once",
                    "object": "checkout.session",
                    "payment_status": "paid",
                    "client_reference_id": "__local__",
                    "metadata": {"owner_id": "__local__", "credits": "25"},
                }
            },
        },
        separators=(",", ":"),
    ).encode()
    headers = {"stripe-signature": _stripe_signature(payload, "whsec_test")}
    first = client.post("/api/ai/webhooks/stripe", content=payload, headers=headers)
    second = client.post("/api/ai/webhooks/stripe", content=payload, headers=headers)
    assert first.status_code == 200
    assert second.json() == {"status": "duplicate"}
    assert client.get("/api/ai/credits").json()["balance"] == balance_before + 25


