def test_provider_failure_callback_refunds_once(client, monkeypatch) -> None:
    monkeypatch.setattr(settings, "ai_provider", "http")
    monkeypatch.setattr(settings, "ai_inline_jobs", False)
    monkeypatch.setattr(settings, "ai_webhook_secret", "provider-secret")
    balance_before = client.get("/api/ai/credits").json()["balance"]
    created = client.post(
        "/api/ai/generations",
        headers={"Idempotency-Key": "provider-refund-once"},
        json={"prompt": "A request that the provider rejects"},
    )
    assert created.status_code == 202
    job_id = created.json()["id"]
    with Session(engine) as session:
        job = session.get(GenerationJobRow, job_id)
        assert job is not None
        job.status = "running"
        job.provider_request_id = "provider-request-refund"
        session.add(job)
        session.commit()

    payload = json.dumps(
        {
            "event_id": "provider-event-refund",
            "request_id": "provider-request-refund",
            "status": "failed",
            "error": "provider rejected request",
        },
        separators=(",", ":"),
    ).encode()
    signature = hmac.new(
        b"provider-secret", payload, hashlib.sha256
    ).hexdigest()
    headers = {"X-OPK-Signature": f"sha256={signature}"}
    first = client.post(
        "/api/ai/webhooks/provider/http", content=payload, headers=headers
    )
    second = client.post(
        "/api/ai/webhooks/provider/http", content=payload, headers=headers
    )
    assert first.json() == {"status": "accepted"}
    assert second.json() == {"status": "duplicate"}
    assert client.get("/api/ai/credits").json()["balance"] == balance_before


def test_webhook_payload_size_is_bounded(client, monkeypatch) -> None:
    monkeypatch.setattr(settings, "ai_webhook_secret", "provider-secret")
    response = client.post(
        "/api/ai/webhooks/provider/http",
        content=b"x" * (1024 * 1024 + 1),
        headers={"X-OPK-Signature": "ignored"},
    )
    assert response.status_code == 413


def test_cancelled_job_ignores_late_provider_success(client, monkeypatch) -> None:
    monkeypatch.setattr(settings, "ai_provider", "http")
    monkeypatch.setattr(settings, "ai_inline_jobs", False)
    monkeypatch.setattr(settings, "ai_webhook_secret", "provider-secret")
    balance_before = client.get("/api/ai/credits").json()["balance"]
    created = client.post(
        "/api/ai/generations",
        headers={"Idempotency-Key": "cancel-before-callback"},
        json={"prompt": "Cancel this request"},
    )
    job_id = created.json()["id"]
    with Session(engine) as session:
        job = session.get(GenerationJobRow, job_id)
        assert job is not None
        job.status = "running"
        job.provider_request_id = "provider-request-cancelled"
        session.add(job)
        session.commit()
    cancelled = client.post(f"/api/ai/generations/{job_id}/cancel")
    assert cancelled.json()["status"] == "cancelled"

    payload = json.dumps(
        {
            "event_id": "provider-event-after-cancel",
            "request_id": "provider-request-cancelled",
            "status": "succeeded",
            "output_url": "https://provider.example/too-late.png",
        },
        separators=(",", ":"),
    ).encode()
    signature = hmac.new(
        b"provider-secret", payload, hashlib.sha256
    ).hexdigest()
    headers = {"X-OPK-Signature": signature}
    assert client.post(
        "/api/ai/webhooks/provider/http", content=payload, headers=headers
    ).json() == {"status": "accepted"}
    assert client.post(
        "/api/ai/webhooks/provider/http", content=payload, headers=headers
    ).json() == {"status": "duplicate"}
    final = client.get(f"/api/ai/generations/{job_id}").json()
    assert final["status"] == "cancelled"
    assert final["output_url"] is None
    assert client.get("/api/ai/credits").json()["balance"] == balance_before
