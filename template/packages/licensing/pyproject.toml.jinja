[project]
name = "{{ pkg_slug }}-licensing"
version = "0.1.0"
description = "Licensing / entitlement: dev stub, Ed25519 signed tokens (offline), file and HTTP providers."
requires-python = ">={{ python_version }}"
dependencies = [
    "cryptography>=42",
]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ pkg_slug }}_licensing"]
