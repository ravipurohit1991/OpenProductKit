"""Core tests run with zero infrastructure — the proof that the core is pure.

The repository is a plain in-memory fake; no database, no FastAPI, no network.
"""

import pytest

from {{ pkg_slug }}_core.domain.note import Note
from {{ pkg_slug }}_core.errors import NoteNotFoundError
from {{ pkg_slug }}_core.services.notes import NoteService


class FakeNoteRepository:
    def __init__(self) -> None:
        self._store: dict[str, Note] = {}

    def add(self, note: Note) -> None:
        self._store[note.id] = note

    def list(self) -> list[Note]:
        return list(self._store.values())

    def get(self, note_id: str) -> Note | None:
        return self._store.get(note_id)


def test_create_and_list() -> None:
    svc = NoteService(FakeNoteRepository())
    note = svc.create("hello", "world")
    assert svc.list() == [note]
    assert svc.get(note.id) == note


def test_get_missing_raises() -> None:
    svc = NoteService(FakeNoteRepository())
    with pytest.raises(NoteNotFoundError):
        svc.get("does-not-exist")


def test_empty_title_rejected() -> None:
    with pytest.raises(ValueError):
        Note(title="   ")
