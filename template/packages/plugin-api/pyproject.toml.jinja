[project]
name = "{{ pkg_slug }}-plugin-api"
version = "0.1.0"
description = "Extension SDK: the contract that plugins implement. No runtime deps."
requires-python = ">={{ python_version }}"
dependencies = []

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ pkg_slug }}_plugin_api"]
