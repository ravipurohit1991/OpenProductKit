# Copy to .env and adjust. Values here are the built-in defaults.
APP_DATABASE_URL=sqlite:///./app.db
{%- if database == 'postgres' %}
# Local dev uses SQLite out of the box; the Docker stack runs PostgreSQL.
# To develop against the stack's database instead ({{ cli_name }} stack up first):
# APP_DATABASE_URL=postgresql+psycopg://app:app@localhost:5432/app
{%- endif %}

# --- Auth (hosted deployments) -------------------------------------------------
# Optional user accounts. Off by default; the desktop/local story has none.
# When on: first visit creates the admin account (or `{{ cli_name }} user add`),
# every API route needs a login, and operator actions need an admin.
APP_AUTH_ENABLED=false
# How long a login session stays valid, in days.
APP_AUTH_SESSION_DAYS=30
{%- if include_ai_saas %}

# --- AI SaaS runtime ----------------------------------------------------------
# `mock` completes jobs locally. `http` POSTs the documented provider contract
# to APP_AI_PROVIDER_URL and accepts HMAC-signed callbacks.
APP_AI_PROVIDER=mock
APP_AI_PROVIDER_URL=
APP_AI_API_KEY=
APP_AI_WEBHOOK_SECRET=replace-with-a-long-random-secret
APP_AI_DEFAULT_MODEL=default
APP_AI_GENERATION_COST=1
APP_AI_TRIAL_CREDITS=10
# Local/dev can process after the response. Docker sets this false and runs the
# durable worker service instead.
APP_AI_INLINE_JOBS=true
# Reclaim jobs left running without a provider request ID after worker failure.
# Provider gateways must treat job_id as an idempotency key before accepting work.
APP_AI_JOB_LEASE_SECONDS=300
APP_AI_PUBLIC_URL=http://127.0.0.1:8000
APP_AI_UPLOAD_DIR=data/uploads
APP_AI_MAX_UPLOAD_BYTES=10485760
APP_AI_ALLOWED_CONTENT_TYPES=image/png,image/jpeg,image/webp
# Signs short-lived input URLs so an external provider can fetch private assets.
APP_AI_ASSET_SIGNING_SECRET=replace-with-a-different-long-random-secret
APP_AI_ASSET_URL_SECONDS=900
# `local` works for desktop/single-server. Use `s3` for horizontally scaled web.
APP_AI_STORAGE_BACKEND=local
APP_AI_S3_BUCKET=
APP_AI_S3_REGION=
APP_AI_S3_ENDPOINT_URL=
APP_AI_S3_ACCESS_KEY_ID=
APP_AI_S3_SECRET_ACCESS_KEY=
APP_AI_S3_PRESIGN_SECONDS=900

# Stripe one-time credit packs. Use Price IDs created in Stripe.
APP_STRIPE_SECRET_KEY=
APP_STRIPE_WEBHOOK_SECRET=
APP_STRIPE_CREDIT_PACKS={"starter":{"price_id":"price_replace_me","credits":100}}
APP_STRIPE_SUCCESS_URL=http://127.0.0.1:5173/?checkout=success
APP_STRIPE_CANCEL_URL=http://127.0.0.1:5173/?checkout=cancelled
{%- endif %}

# --- Marketplace --------------------------------------------------------------
# Catalog of extensions shown in the Marketplace tab (defaults to the local file).
APP_MARKETPLACE_CATALOG=marketplace/catalog.json
# Or host the catalog and update it without shipping app releases.
APP_MARKETPLACE_URL=
# Allow installing catalog extensions from the running app (Marketplace Install
# button). Installing runs pip in the app's environment — leave off unless the
# catalog is vendor-controlled and you trust every package in it.
APP_MARKETPLACE_ALLOW_INSTALL=false

# --- Licensing --------------------------------------------------------------
# Your vendor Ed25519 public key (`{{ cli_name }} license keygen` prints it).
# Without it, signed license tokens cannot be verified.
APP_LICENSE_PUBLIC_KEY=

# How a customer install gets its license (pick one):
#   a token directly in the environment ...
APP_LICENSE_TOKEN=
#   ... or a file written by `{{ cli_name }} license install <token>` ...
APP_LICENSE_FILE=license.key
#   ... or a vendor-run HTTP validation endpoint (takes precedence when set).
APP_LICENSE_URL=

# Plan the dev stub grants while nothing above is configured (free|pro|enterprise).
APP_LICENSE_DEV_PLAN=pro
