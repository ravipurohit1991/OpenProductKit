[project]
name = "{{ pkg_slug }}-plugin-basic"
version = "0.1.0"
description = "Example free plugin: contributes a backend route and a settings schema."
requires-python = ">={{ python_version }}"
dependencies = [
    "{{ pkg_slug }}-plugin-api",
    "fastapi>=0.115",
]

[project.entry-points."{{ pkg_slug }}.plugins"]
basic = "{{ pkg_slug }}_plugin_basic:PLUGIN"

[tool.uv.sources]
"{{ pkg_slug }}-plugin-api" = { workspace = true }

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ pkg_slug }}_plugin_basic"]
