[project]
name = "{{ pkg_slug }}-plugin-reports"
version = "0.1.0"
description = "A marketplace-distributed extension: in the repo, installed on demand."
requires-python = ">={{ python_version }}"
dependencies = [
    "{{ pkg_slug }}-plugin-api",
    "fastapi>=0.115",
]

[project.entry-points."{{ pkg_slug }}.plugins"]
reports = "{{ pkg_slug }}_plugin_reports:PLUGIN"

[tool.uv.sources]
"{{ pkg_slug }}-plugin-api" = { workspace = true }

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ pkg_slug }}_plugin_reports"]
