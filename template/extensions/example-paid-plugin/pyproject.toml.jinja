[project]
name = "{{ pkg_slug }}-plugin-paid"
version = "0.1.0"
description = "Example license-gated plugin: analytics summary (requires the 'pro' plan)."
requires-python = ">={{ python_version }}"
dependencies = [
    "{{ pkg_slug }}-plugin-api",
    "{{ pkg_slug }}-backend",
    "fastapi>=0.115",
    "sqlmodel>=0.0.22",
]

[project.entry-points."{{ pkg_slug }}.plugins"]
paid = "{{ pkg_slug }}_plugin_paid:PLUGIN"

[tool.uv.sources]
"{{ pkg_slug }}-plugin-api" = { workspace = true }
"{{ pkg_slug }}-backend" = { workspace = true }

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ pkg_slug }}_plugin_paid"]
