[project]
name = "{{ pkg_slug }}-plugin-cli"
version = "0.1.0"
description = "Example free plugin: contributes a CLI command group."
requires-python = ">={{ python_version }}"
dependencies = [
    "{{ pkg_slug }}-plugin-api",
    "typer>=0.12",
]

[project.entry-points."{{ pkg_slug }}.plugins"]
cli = "{{ pkg_slug }}_plugin_cli:PLUGIN"

[tool.uv.sources]
"{{ pkg_slug }}-plugin-api" = { workspace = true }

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ pkg_slug }}_plugin_cli"]
